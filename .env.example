PORT=3000

DATABASE_URL=postgresql://user:password@host/db?sslmode=require

JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_TOKEN_EXPIRED=1d

JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_TOKEN_EXPIRED=7d

MAILER_USER=your_email@example.com
MAILER_PASSWORD=your_email_password
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=465
MAIL_SENDER_DEFAULT=your_email@example.com
MAIL_SENDER_NAME_DEFAULT=IELTS Training App

CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_NAME=your_cloudinary_cloud_name

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALL_BACK_URL=https://your-domain.com/auth/google/callback

GEMINI_API_KEY=your_gemini_api_key

AI_MICROSERVICE_SECRET=your_ai_microservice_secret

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
LOG_LEVEL=info
NODE_ENV=production

# Supabase (used by chatbot and embedding workers)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# VNPay Configuration (Sandbox)
VNPAY_TMN_CODE=your_tmn_code_from_sandbox
VNPAY_HASH_SECRET=your_hash_secret_from_sandbox
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay/return
VNPAY_IPN_URL=http://localhost:3000/payment/vnpay/ipn
VNPAY_SANDBOX=true