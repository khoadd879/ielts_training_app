# Shared AI Workers Environment Configuration
# Copy this file to .env and fill in your values

# Common
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
LOG_LEVEL=info
NODE_ENV=production

# Groq API (used by all workers)
GROQ_API_KEY=your_groq_api_key_here

# Supabase (used by chatbot and embedding workers)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Neon Database (used by grading worker)
NEON_DATABASE_URL=postgresql://user:password@host/db?sslmode=require
