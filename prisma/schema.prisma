generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  idUser      String      @id @default(uuid())
  nameUser    String?
  email       String      @unique
  password    String
  phoneNumber String?
  address     String?
  role        Role        @default(USER)
  avatar      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  accountType AccountType @default(LOCAL)
  isActive    Boolean     @default(false)
  gender      Gender      @default(Male)

  // Gamification
  level         Level     @default(Low)
  xp            Int       @default(0)
  xpToNext      Int       @default(100)
  currentStreak Int       @default(0)
  lastStudiedAt DateTime?
  longestStreak Int       @default(0)

  // IELTS targets
  targetBandScore Float?
  targetExamDate  DateTime?

  // Relations
  verificationCodes       VerificationCode[]
  tests                   Test[]
  userTestResults         UserTestResult[]
  userAnswers             UserAnswer[]
  userWritingSubmissions  UserWritingSubmission[]
  userSpeakingSubmissions UserSpeakingSubmission[]

  // Vocabulary & Grammar
  topics            Topic[]
  vocabularies      Vocabulary[]
  grammarCategories GrammarCategory[]

  // Credits
  creditBalance      CreditBalance?
  creditTransactions CreditTransaction[]

  // Subscriptions
  subscriptions UserSubscription[]

  // Forum
  forumThreads      ForumThreads[]
  forumPosts        ForumPost[]
  forumComments     ForumComment[]
  forumPostLikes    ForumPostLikes[]
  forumCommentLikes ForumCommentLikes[]

  // Teacher Review
  teacherReviewTickets    TeacherReviewTicket[]
  teacherReviewTicketsAsTeacher TeacherReviewTicket[] @relation("TeacherReviewTickets")
}

model VerificationCode {
  idCode     String   @id @default(uuid())
  idUser     String
  token      String
  type       OTPType
  expiration DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
}

// ============================================================================
// EXAM CORE — Test → Part → Passage / QuestionGroup → Question
// ============================================================================

model Test {
  idTest         String   @id @default(uuid())
  idUser         String
  title          String
  description    String?
  img            String?
  testType       TestType
  duration       Int /// Total duration in seconds
  numberQuestion Int /// Total number of questions
  audioUrl       String? /// Master audio URL (for Listening tests)
  level          Level    @default(Low)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  parts           Part[]
  writingTasks    WritingTask[]
  speakingTasks   SpeakingTask[]
  userTestResults UserTestResult[]

  @@index([testType, level])
}

model Part {
  idPart    String   @id @default(uuid())
  idTest    String
  namePart  String /// e.g. "Part 1", "Section 1"
  order     Int      @default(0)
  audioUrl  String? /// Part-level audio (for Listening)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  test           Test            @relation(fields: [idTest], references: [idTest], onDelete: Cascade)
  passage        Passage?
  questionGroups QuestionGroup[]
  questions      Question[]

  @@unique([idTest, order])
  @@index([idTest])
}

model Passage {
  idPassage       String   @id @default(uuid())
  idPart          String   @unique
  title           String
  content         String /// Full passage text (HTML/Markdown)
  image           String?
  description     String?
  audioUrl        String? /// Passage-level audio (for Listening passages)
  numberParagraph Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  part Part @relation(fields: [idPart], references: [idPart], onDelete: Cascade)
}

/// A group of questions sharing the same type and instructions.
/// e.g. "Questions 1-5: Choose TRUE, FALSE, or NOT GIVEN"
model QuestionGroup {
  idQuestionGroup String       @id @default(uuid())
  idPart          String
  title           String /// Group heading shown to students
  instructions    String? /// Detailed instructions for the group
  questionType    QuestionType /// All questions in this group share this type
  imageUrl        String? /// Image for the group (e.g. map, diagram)
  order           Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  part      Part       @relation(fields: [idPart], references: [idPart], onDelete: Cascade)
  questions Question[]

  @@index([idPart, order])
}

/// Polymorphic Question model.
/// The `metadata` JSONB column stores all type-specific data
/// (options, correct answers, coordinates, word banks, etc.).
/// Use the `questionType` discriminator to interpret the metadata.
model Question {
  idQuestion      String       @id @default(uuid())
  idQuestionGroup String
  idPart          String
  questionNumber  Int /// Global question number within the test
  content         String /// Question text / prompt
  questionType    QuestionType /// Discriminator — mirrors the group type but can differ
  metadata        Json         @db.JsonB /// Type-specific payload (see TS interfaces)
  order           Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  questionGroup QuestionGroup @relation(fields: [idQuestionGroup], references: [idQuestionGroup], onDelete: Cascade)
  part          Part          @relation(fields: [idPart], references: [idPart], onDelete: Cascade)
  userAnswers   UserAnswer[]

  @@index([idQuestionGroup, order])
  @@index([idPart, questionNumber])
}

// ============================================================================
// EXAM CORE — Writing & Speaking Task Definitions
// ============================================================================

model WritingTask {
  idWritingTask String          @id @default(uuid())
  idTest        String
  title         String
  taskType      WritingTaskType
  timeLimit     Int /// Time limit in seconds
  image         String? /// Stimulus image (charts, graphs for Task 1)
  instructions  String? /// Task instructions
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  test                   Test                    @relation(fields: [idTest], references: [idTest], onDelete: Cascade)
  userWritingSubmissions UserWritingSubmission[]
}

model SpeakingTask {
  idSpeakingTask String           @id @default(uuid())
  idTest         String
  title          String
  part           SpeakingPartType
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  test            Test                     @relation(fields: [idTest], references: [idTest], onDelete: Cascade)
  questions       SpeakingQuestion[]
  userSubmissions UserSpeakingSubmission[]

  @@unique([idTest, part])
}

model SpeakingQuestion {
  idSpeakingQuestion String  @id @default(uuid())
  idSpeakingTask     String
  topic              String? /// e.g. "Hometown", "Work/Study"
  prompt             String? /// Question text
  subPrompts         Json? /// Cue card bullet points (Part 2)
  preparationTime    Int     @default(0)
  speakingTime       Int     @default(120)
  order              Int     @default(0)

  // Relations
  speakingTask SpeakingTask @relation(fields: [idSpeakingTask], references: [idSpeakingTask], onDelete: Cascade)

  @@index([idSpeakingTask, order])
}

// ============================================================================
// USER TEST RESULTS & ANSWERS
// ============================================================================

model UserTestResult {
  idTestResult   String     @id @default(uuid())
  idUser         String
  idTest         String
  score          Int?       @default(0) /// Raw score (out of 40 for R/L)
  totalCorrect   Int?       @default(0)
  totalQuestions Int?       @default(0)
  rawScore       Int?       @default(0)
  bandScore      Float      @default(0)
  duration       Int        @default(0) /// Actual time spent in seconds
  status         TestStatus @default(IN_PROGRESS)
  level          Level      @default(Low)
  startedAt      DateTime   @default(now())
  finishedAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  user                 User                     @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  test                 Test                     @relation(fields: [idTest], references: [idTest], onDelete: Cascade)
  userAnswers          UserAnswer[]
  writingSubmissions   UserWritingSubmission[]
  speakingSubmissions  UserSpeakingSubmission[]
  teacherReviewTickets TeacherReviewTicket[]

  @@index([idUser, status, finishedAt])
  @@index([idTest, createdAt])
}

model UserAnswer {
  idUserAnswer  String       @id @default(uuid())
  idUser        String
  idQuestion    String
  idTestResult  String
  answerType    QuestionType /// Mirrors the question type for easy filtering
  answerPayload Json         @db.JsonB /// Structured answer (text, selected option index, matching pairs, etc.)
  isCorrect     Boolean      @default(false)
  submittedAt   DateTime     @default(now())

  // Relations
  user       User           @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  question   Question       @relation(fields: [idQuestion], references: [idQuestion], onDelete: Cascade)
  testResult UserTestResult @relation(fields: [idTestResult], references: [idTestResult], onDelete: Cascade)

  @@unique([idQuestion, idUser, idTestResult])
  @@index([idTestResult, isCorrect])
}

// ============================================================================
// ASYNC SUBMISSIONS — Writing (AI-graded via RabbitMQ)
// ============================================================================

model UserWritingSubmission {
  idWritingSubmission String  @id @default(uuid())
  idUser              String
  idWritingTask       String
  idTestResult        String?

  submissionText String /// The student's essay

  // Async grading state machine
  aiGradingStatus    GradingStatus @default(PENDING)
  aiOverallScore     Float? /// Band score (0.0 – 9.0)
  aiDetailedFeedback Json?         @db.JsonB /// { ta, cc, lr, gra } with scores + comments
  submittedAt        DateTime      @default(now())
  gradedAt           DateTime? /// Set when AI worker returns result

  // Relations
  user        User            @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  writingTask WritingTask     @relation(fields: [idWritingTask], references: [idWritingTask], onDelete: Cascade)
  testResult  UserTestResult? @relation(fields: [idTestResult], references: [idTestResult], onDelete: Cascade)

  // Credits - FK stored here, relation via idWritingSubmission in CreditTransaction
  idCreditTransaction String?

  @@index([idUser, aiGradingStatus, submittedAt])
  @@index([aiGradingStatus]) // For worker polling
}

// ============================================================================
// ASYNC SUBMISSIONS — Speaking (AI-graded via RabbitMQ)
// ============================================================================

model UserSpeakingSubmission {
  idSpeakingSubmission String  @id @default(uuid())
  idUser               String
  idSpeakingTask       String
  idTestResult         String?

  audioUrl   String /// Uploaded audio file URL
  transcript String? /// AI-generated transcript

  // Async grading state machine
  aiGradingStatus    GradingStatus @default(PENDING)
  aiOverallScore     Float? /// Band score (0.0 – 9.0)
  aiDetailedFeedback Json?         @db.JsonB /// { fc, lr, gra, pronunciation } with scores + comments
  submittedAt        DateTime      @default(now())
  gradedAt           DateTime? /// Set when AI worker returns result

  // Relations
  user         User            @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  speakingTask SpeakingTask    @relation(fields: [idSpeakingTask], references: [idSpeakingTask], onDelete: Cascade)
  testResult   UserTestResult? @relation(fields: [idTestResult], references: [idTestResult])

  // Credits - FK stored here, relation via idSpeakingSubmission in CreditTransaction
  idCreditTransaction String?

  @@index([idUser, aiGradingStatus, submittedAt])
  @@index([aiGradingStatus]) // For worker polling
}

// ============================================================================
// VOCABULARY & GRAMMAR
// ============================================================================

model Vocabulary {
  idVocab       String    @id @default(uuid())
  word          String
  phonetic      String?
  meaning       String
  example       String?
  VocabType     VocabType
  level         Level?
  correctStreak Int       @default(0)
  lastReviewed  DateTime?
  xp            Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  idUser        String
  idTopic       String?

  // Relations
  topic Topic? @relation(fields: [idTopic], references: [idTopic], onDelete: Cascade)
  user  User   @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
}

model Topic {
  idTopic   String   @id @default(uuid())
  nameTopic String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  idUser    String

  // Relations
  user       User         @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  vocabulary Vocabulary[]
}

model GrammarCategory {
  idGrammarCategory String   @id @default(uuid())
  name              String
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  idUser            String?

  // Relations
  user     User?                  @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  grammars GrammarsOnCategories[]

  @@unique([idUser, name])
}

model Grammar {
  idGrammar      String   @id @default(uuid())
  title          String
  explanation    String
  level          Level    @default(Low)
  commonMistakes Json?
  examples       Json?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  categories GrammarsOnCategories[]
}

model GrammarsOnCategories {
  idGrammarCategory String
  idGrammar         String
  assignedAt        DateTime @default(now())
  assignedBy        String

  // Relations
  category GrammarCategory @relation(fields: [idGrammarCategory], references: [idGrammarCategory], onDelete: Cascade)
  grammar  Grammar         @relation(fields: [idGrammar], references: [idGrammar], onDelete: Cascade)

  @@id([idGrammarCategory, idGrammar])
}

// ============================================================================
// FORUM
// ============================================================================

model ForumThreads {
  idForumThreads String   @id @default(uuid())
  idUser         String
  title          String
  content        String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  user      User        @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  forumPost ForumPost[]
}

model ForumPost {
  idForumPost      String                @id @default(uuid())
  idForumThreads   String
  idUser           String
  content          String
  file             String?
  moderationStatus ForumModerationStatus @default(PENDING)
  moderationScore  Int?
  moderationMeta   Json?                 @db.JsonB
  reviewedBy       String?
  reviewedAt       DateTime?
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt

  // Relations
  forumThreads   ForumThreads     @relation(fields: [idForumThreads], references: [idForumThreads], onDelete: Cascade)
  user           User             @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  forumComment   ForumComment[]
  forumPostLikes ForumPostLikes[]

  @@index([idForumThreads, created_at])
  @@index([moderationStatus, created_at])
}

model ForumComment {
  idForumComment String   @id @default(uuid())
  idForumPost    String
  idUser         String
  content        String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  forumPost         ForumPost           @relation(fields: [idForumPost], references: [idForumPost], onDelete: Cascade)
  user              User                @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  forumCommentLikes ForumCommentLikes[]
}

model ForumPostLikes {
  idForumPostLikes String   @id @default(uuid())
  idForumPost      String
  idUser           String
  created_at       DateTime @default(now())

  // Relations
  forumPost ForumPost @relation(fields: [idForumPost], references: [idForumPost], onDelete: Cascade)
  user      User      @relation(fields: [idUser], references: [idUser], onDelete: Cascade)

  @@unique([idForumPost, idUser])
}

model ForumCommentLikes {
  idForumCommentLikes String   @id @default(uuid())
  idForumComment      String
  idUser              String
  created_at          DateTime @default(now())

  // Relations
  forumComment ForumComment @relation(fields: [idForumComment], references: [idForumComment], onDelete: Cascade)
  user         User         @relation(fields: [idUser], references: [idUser], onDelete: Cascade)

  @@unique([idForumComment, idUser])
}

// ============================================================================
// CREDITS & MONETIZATION
// ============================================================================

model CreditPackage {
  idPackage    String   @id @default(uuid())
  name         String   @unique
  description  String?
  creditAmount Int
  price        Float
  priceUnit    String   @default("VND") // VND, USD
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  transactions CreditTransaction[]

  @@index([isActive, sortOrder])
}

model CreditBalance {
  idUser        String @id @default(uuid())
  totalCredits  Int    @default(0)
  usedCredits   Int    @default(0)
  frozenCredits Int    @default(0) // Reserved for pending submissions

  // Relations
  user         User                @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  transactions CreditTransaction[]

  @@index([idUser])
}

model CreditTransaction {
  idTransaction        String            @id @default(uuid())
  idUser               String
  idPackage            String?
  creditsAmount        Int
  transactionType      CreditTransType
  description          String?
  idWritingSubmission  String?
  idSpeakingSubmission String?
  status               CreditTransStatus @default(PENDING)
  createdAt            DateTime          @default(now())

  // Relations
  user                User           @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  package             CreditPackage? @relation(fields: [idPackage], references: [idPackage])
  creditBalance       CreditBalance? @relation(fields: [creditBalanceIdUser], references: [idUser])
  creditBalanceIdUser String?

  @@index([idUser, createdAt])
  @@index([transactionType, createdAt])
}

// ============================================================================
// SUBSCRIPTION (Pay-as-you-go credits + Subscription tiers)
// ============================================================================

model SubscriptionPackage {
  idPackage    String       @id @default(uuid())
  name         String       @unique // "Monthly Pro", "Annual Premium"
  description  String?
  billingCycle BillingCycle @default(MONTHLY) // MONTHLY, ANNUAL
  price        Float
  priceUnit    String       @default("VND")
  creditsQuota Int          @default(0) // 0 = unlimited
  features     String[] // ["AI Writing", "AI Speaking", "Priority Queue"]
  badge        String? // "Popular", "Best Value"
  isActive     Boolean      @default(true)
  isFeatured   Boolean      @default(false)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  subscriptions UserSubscription[]

  @@index([isActive, sortOrder])
  @@index([billingCycle])
}

model UserSubscription {
  idSubscription String             @id @default(uuid())
  idUser         String
  idPackage      String
  status         SubscriptionStatus @default(ACTIVE)
  startedAt      DateTime           @default(now())
  expiresAt      DateTime // End of billing period
  nextBillingAt  DateTime? // For recurring billing
  autoRenew      Boolean            @default(true)

  // Quota tracking (for limited subscriptions)
  creditsUsedThisPeriod  Int @default(0)
  creditsQuotaThisPeriod Int @default(0)

  // Payment
  paymentRef    String? // Payment gateway reference
  paymentMethod PaymentMethod? // MOMO, VNPAY, STRIPE, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User                @relation(fields: [idUser], references: [idUser], onDelete: Cascade)
  package SubscriptionPackage @relation(fields: [idPackage], references: [idPackage])

  @@index([idUser, status])
  @@index([expiresAt])
}

enum CreditTransType {
  PURCHASE // User mua package
  USED_WRITING // Dùng cho writing submission
  USED_SPEAKING // Dùng cho speaking submission
  REFUND // Hoàn credit (grading fail)
  EXPIRY // Credit hết hạn
  BONUS // Credit bonus (promotion, referral)
  ADMIN_ADJUST // Admin điều chỉnh
}

enum CreditTransStatus {
  PENDING // Đang xử lý
  COMPLETED // Hoàn tất
  FAILED // Thất bại
  CANCELLED // Bị hủy
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE // Đang sử dụng, quota còn
  EXPIRED // Hết hạn (không renew được)
  CANCELLED // User hủy
  SUSPENDED // Admin suspend
}

enum PaymentMethod {
  MOMO
  VNPAY
  STRIPE
  BANK_TRANSFER
  ADMIN_CREDIT // Admin tặng
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  USER
  ADMIN
  GIAOVIEN
}

enum AccountType {
  LOCAL
  GOOGLE
}

enum Gender {
  Male
  Female
}

enum OTPType {
  OTP
  RESET_LINK
}

enum Level {
  Low
  Mid
  High
  Great
}

enum TestType {
  LISTENING
  READING
  WRITING
  SPEAKING
}

enum TestStatus {
  IN_PROGRESS
  FINISHED
  EXPIRED
  CANCELLED
}

enum AssignMode {
  AUTO
  MANUAL
}

/// All 14 IELTS Reading/Listening question types
enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE_NOT_GIVEN
  YES_NO_NOT_GIVEN
  MATCHING_HEADING
  MATCHING_INFORMATION
  MATCHING_FEATURES
  MATCHING_SENTENCE_ENDINGS
  SENTENCE_COMPLETION
  SUMMARY_COMPLETION
  NOTE_COMPLETION
  TABLE_COMPLETION
  FLOW_CHART_COMPLETION
  DIAGRAM_LABELING
  SHORT_ANSWER
}

enum WritingTaskType {
  TASK1
  TASK2
}

enum SpeakingPartType {
  PART1
  PART2
  PART3
}

/// Async grading state machine for AI Worker (RabbitMQ)
enum GradingStatus {
  PENDING /// Submission received, queued
  GRADING /// AI Worker is processing
  COMPLETED /// Grading finished successfully
  FAILED /// Grading failed (retry or manual review)
}

enum ForumModerationStatus {
  PENDING
  AUTO_APPROVED
  NEEDS_REVIEW
  AUTO_REJECTED
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum VocabType {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PHRASE
  IDIOM
  PREPOSITION
  CONJUNCTION
  INTERJECTION
}

enum ReviewType {
  WRITING
  SPEAKING
}

enum TeacherReviewStatus {
  PENDING
  CLAIMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TeacherReviewTicket {
  idTicket         String              @id @default(uuid())
  idTestResult     String
  idUser           String
  type             ReviewType
  status           TeacherReviewStatus @default(PENDING)
  aiBandScore      Float?
  aiFeedback       Json?
  idTeacher        String?
  claimedAt        DateTime?
  teacherBandScore Float?
  teacherFeedback  Json?
  submittedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  commissionAmount Float?

  // Relations
  testResult UserTestResult @relation(fields: [idTestResult], references: [idTestResult], onDelete: Cascade, onUpdate: Cascade)
  user       User           @relation(fields: [idUser], references: [idUser], onDelete: Cascade, onUpdate: Cascade)
  teacher    User?          @relation("TeacherReviewTickets", fields: [idTeacher], references: [idUser], onDelete: SetNull, onUpdate: Cascade)

  @@index([status, createdAt])
  @@index([idTeacher, status])
  @@index([idUser, status])
}

// ============================================================================
// SYSTEM CONFIG - Lưu cấu hình hệ thống (commission, assign mode, etc.)
// ============================================================================

model SystemConfig {
  idConfig     String     @id // VD: "teacher_review_commission", "assign_mode"
  value        Json       // VD: { "writing": 50000, "speaking": 40000 }
  assignMode   AssignMode @default(MANUAL) // Chỉ dùng cho assign_mode record
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([idConfig])
}
